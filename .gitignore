bin/
obj/

# NuGet packages (keep only the latest, tracked by build.ps1)
*.nupkg

# Inspector tool (used only for API discovery during development)
inspector/bin/
inspector/obj/

# GitExtensions binaries baixados pelo pacote GitExtensions.Extensibility (prebuild)
gitextensions.shared/

# Visual Studio / Rider
.vs/
.idea/
*.user
*.suo

# Arquivos de backup gerados pelo build.ps1
*.bak

# Cofre Obsidian: mora fora do repo (~/OBSIDIAN/CLAUDE); a cópia in-repo é legada
OBSIDIAN/

# OS
Thumbs.db
.DS_Store
