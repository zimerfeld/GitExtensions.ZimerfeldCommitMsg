<?xml version="1.0"?>
<package>
  <metadata>
    <id>GitExtensions.ZimerfeldCommitMsg</id>
    <version>1.0.57</version>
    <authors>Zimerfeld</authors>
    <description>Plugin for GitExtensions that automatically generates commit messages by analyzing the actual content of staged changes. Changes are classified by Conventional Commits type (feat/fix/docs/test/chore/build/refactor) to pick the appropriate verb; the resulting message is a verb-led subject (no literal "type:" prefix) plus a bulleted body. Output is in Brazilian Portuguese or English — selected automatically from the operating system language, with a manual override in the plugin settings. Supports two strategies: comment-based (extracts meaningful comments added to the diff) and filename-based (derives semantic concepts from file names). The message is refreshed automatically whenever files are staged or unstaged while the commit dialog is open.</description>
    <tags>gitextensions plugin commit-message conventional-commits</tags>
    <readme>README.md</readme>
    <icon>images\icon-128.png</icon>
    <license type="expression">MIT</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
  </metadata>
  <files>
    <!-- Plugin DLL -->
    <file src="bin\Release\net9.0-windows\GitExtensions.Plugins.ZimerfeldCommitMsg.dll" target="tools\net9.0-windows\" />
    <!-- Install / Uninstall scripts -->
    <file src="..\..\tools\install.ps1" target="tools\" />
    <file src="..\..\tools\uninstall.ps1" target="tools\" />
    <!-- README e LICENSE -->
    <file src="..\..\README.md" target="\" />
    <file src="..\..\LICENSE.txt" target="\" />
    <!-- Ícone exibido no nuget.org (128x128 px recomendado) -->
    <file src="Resources\icon-128.png" target="images\" />
  </files>
</package>