<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <TargetFramework>net9.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>GitExtensions.Plugins.ZimerfeldCommitMsg</AssemblyName>
    <RootNamespace>GitExtensions.ZimerfeldCommitMsg</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <NeutralLanguage>pt-BR</NeutralLanguage>
    <Version>1.0.4</Version>
    <Authors>Zimerfeld</Authors>
    <Description>GitExtensions plugin that summarizes staged changes into a single commit message sentence</Description>
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <!-- Reference GitExtensions DLLs as private=false so they are NOT copied to output -->
    <Reference Include="GitExtensions.Extensibility">
      <HintPath>C:\Program Files\GitExtensions\GitExtensions.Extensibility.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="GitUIPluginInterfaces">
      <HintPath>C:\Program Files\GitExtensions\GitUIPluginInterfaces.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Reference Include="System.ComponentModel.Composition">
      <HintPath>C:\Program Files\GitExtensions\System.ComponentModel.Composition.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

</Project>
