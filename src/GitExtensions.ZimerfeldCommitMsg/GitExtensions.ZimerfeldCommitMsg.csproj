<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>GitExtensions.Plugins.ZimerfeldCommitMsg</AssemblyName>
    <RootNamespace>GitExtensions.ZimerfeldCommitMsg</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <NeutralLanguage>pt-BR</NeutralLanguage>
    <Version>1.0.93</Version>
    <Authors>Zimerfeld</Authors>
    <Description>GitExtensions plugin that summarizes staged changes into a single commit message sentence</Description>
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
    <!-- GitExtensions hosts the plugin and supplies WindowsBase at runtime; nothing is
         copied to output (Private=false), so the build-time version conflict between the
         net9 ref pack (4.0.0.0) and GitExtensions' VS.Threading (8.0.0.0) is harmless. -->
    <MSBuildWarningsAsMessages>MSB3277</MSBuildWarningsAsMessages>

    <!-- Assemblies de referência do host versionados no repositório (refs/) → build
         determinístico em qualquer máquina Windows, sem download em prebuild e sem rede.
         O download anterior escolhia o primeiro asset 'portable' do release, podendo trazer
         um build arm64 (6.0.5.75) incompatível com o x64 instalado (6.0.5.18375). Ver refs/README.md. -->
    <GitExtensionsRefPath>$(MSBuildProjectDirectory)\..\..\refs</GitExtensionsRefPath>
  </PropertyGroup>

  <ItemGroup>
    <!-- Expõe os tipos internal ao projeto de testes (funções puras do gerador). -->
    <InternalsVisibleTo Include="GitExtensions.ZimerfeldCommitMsg.Tests" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\icon.png" />
    <!-- Strings de UI embutidas no assembly principal (sem satellite assemblies, para
         preservar o deploy de DLL única). LogicalName fixo → nome de recurso determinístico,
         independente de RootNamespace/pasta, casando com os ResourceManager em Strings.cs. -->
    <EmbeddedResource Update="Resources\Strings.resx">
      <LogicalName>GitExtensions.ZimerfeldCommitMsg.Resources.Strings.resources</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Update="Resources\StringsPtBr.resx">
      <LogicalName>GitExtensions.ZimerfeldCommitMsg.Resources.StringsPtBr.resources</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <!-- DLLs do host resolvidas a partir de refs/ (versionado), não mais de um download em
         prebuild. Private=false: o GitExtensions fornece esses assemblies em runtime; nada é
         copiado para a saída. As versões em refs/ devem casar com o GitExtensions x64 6.0.5
         de destino (ver refs/README.md). -->
    <Reference Include="GitExtensions.Extensibility">
      <HintPath>$(GitExtensionsRefPath)\GitExtensions.Extensibility.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="System.ComponentModel.Composition">
      <HintPath>$(GitExtensionsRefPath)\System.ComponentModel.Composition.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

</Project>
